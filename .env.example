# ── Backend (Cloud Run) ────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
BACKEND_URL=https://voxii-tutor-backend-919882895306.australia-southeast1.run.app

# Supabase JWKS — EC public key for ES256 JWT verification. Safe in env (it's a public key).
# From: Supabase Dashboard → Settings → API → JWT Settings → JWKS (copy full JSON)
SUPABASE_JWKS={"keys":[{"x":"...","y":"...","alg":"ES256","crv":"P-256","kty":"EC","kid":"...","key_ops":["verify"]}]}

# Redis session cache — Upstash Redis URL (rediss://...) for persistent sessions.
# Leave blank to fall back to in-memory LRU (dev/local only).
REDIS_URL=

# Dev-only fallback — used by Vite proxy when Supabase is not configured locally.
# Not needed once SUPABASE_JWT_SECRET is set on Cloud Run.
API_SECRET=dev-secret-change-me

# ── Frontend (Vercel / Vite) ───────────────────────────────────────────────────
# VITE_ prefix exposes these to the browser.
# The anon/publishable key is safe to expose — it's designed to be public.
VITE_SUPABASE_URL=https://kizrtirljclpqjifrlwh.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
